FoamFile
{
    format      ascii;
    class       dictionary;
    location    "system";
    object      blockMeshDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

scale 0.001;

vertices
(
    (0 0 0)
    (12 0 0)
    (0 120 0)
    (12 120 0)
    (0 0 12)
    (12 0 12)
    (0 120 12)
    (12 120 12)

);

blocks
(
    hex (0 1 3 2 4 5 7 6)(20 200 20) simpleGrading (1 1 1)
);

defaultPatch
{
    type empty;
}

boundary
(
    leftWall
    {
        type wall;
        faces
        (
            (0 4 6 2)
        );
    }
    rightWall
    {
        type wall;
        faces
        (
            (1 5 7 3)
        );
    }
    lowerWall
    {
        type wall;
        faces
        (
            (0 1 5 4)
        );
    }    
    atmosphere
    {
        type wall;
        faces
        (
            (2 6 7 3)
        );
    }
);


